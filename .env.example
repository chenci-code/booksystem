DJANGO_SECRET_KEY=replace-with-a-secure-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.railway.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.railway.app

# Prefer Railway DATABASE_URL if available.
DATABASE_URL=

# Fallback MySQL variables if you are not using DATABASE_URL.
MYSQLDATABASE=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLHOST=
MYSQLPORT=

# Optional: override crawler source directory.
NOVEL_CRAWLER_DIR=
